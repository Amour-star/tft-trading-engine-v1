# Production template (copy to .env and adjust)
ENV=production
MODE=paper
SPOT_ONLY_MODE=false
PAPER_REQUIRE_LIVE_PRICE=true
USE_CUDA=false

# KuCoin credentials (optional for PAPER/public mode)
KUCOIN_API_KEY=
KUCOIN_API_SECRET=
KUCOIN_API_PASSPHRASE=
# Alias compatibility (kucoin-universal-sdk style deploys)
KUCOIN_KEY=
KUCOIN_SECRET=
KUCOIN_PASSPHRASE=
# Additional alias compatibility (KC_* style deploys)
KC_API_KEY=
KC_API_SECRET=
KC_API_PASSPHRASE=
KUCOIN_REQUIRE_AUTH=false
KUCOIN_AUTH_CHECK_ON_STARTUP=true
ALLOW_SYNTHETIC_ORDERBOOK=false
ALLOW_SYNTHETIC_TICKER=false
ALLOW_SYNTHETIC_KLINES=false
ORDERBOOK_RETRY_ATTEMPTS=3
KUCOIN_HTTP_RETRY_ATTEMPTS=4
KUCOIN_HTTP_TIMEOUT_SECONDS=4.0
KUCOIN_HTTP_MAX_BACKOFF_SECONDS=8.0
MARKET_DATA_MAX_AGE_SECONDS=30
MARKET_DATA_SYMBOLS=BTC-USDT,ETH-USDT,XRP-USDT,DOGE-USDT
MARKET_TICKER_CHANNEL=market:ticker
MARKET_TICKER_KEY_PREFIX=market:ticker:
MARKET_HALT_KEY_PREFIX=market:halt:
MARKET_CONTROL_CHANNEL=market:control
MARKET_HEALTH_KEY=market:health:market-data

MAX_POSITION_PCT=1.0
MAX_NOTIONAL_PER_TRADE=1000000000
CONFIDENCE_THRESHOLD=0.50
AGGRESSION_LEVEL=1.0
ALLOW_SHORTS=true
MAX_OPEN_TRADES=3
MAX_SPREAD_PCT=0.005
METRICS_MIN_TRADES=20
METRICS_MIN_WINDOW_TRADES=5

KILL_SWITCH_DAILY_DRAWDOWN=0.15
KILL_SWITCH_BALANCE_DROP=0.30

LOG_LEVEL=INFO

# Required for dashboard admin endpoints
ADMIN_TOKEN=change_me

# Database (SQLite default; keep if using SQLITE)
DATABASE_MODE=SQLITE
SQLITE_PATH=/app/state/tft_engine.db
SQLITE_WAL_MODE=false
SQLITE_JOURNAL_MODE=DELETE
SQLITE_FALLBACK_JOURNAL_MODE=DELETE
SQLITE_POOL_SIZE=8
SQLITE_MAX_OVERFLOW=16
SQLITE_POOL_TIMEOUT_SECONDS=30
PAPER_DB_PATH=/app/state/paper_trading.db
PAPER_DB_JOURNAL_MODE=DELETE
ENGINE_LOCK_FILE=/app/state/tft_engine.lock

# Host-side dashboard port mapping
DASHBOARD_HOST_PORT=8501

# Quant multi-asset engine (new)
QUANT_ENGINE_ENABLED=true
UNIVERSE=BTC-USDT,ETH-USDT,SOL-USDT,BNB-USDT,DOGE-USDT,XRP-USDT,AVAX-USDT
UNIVERSE_AUTO_EXPAND=true
MAX_UNIVERSE_SIZE=14
ENGINE_MARKET_INTERVAL_SECONDS=10
ENGINE_SIGNAL_INTERVAL_SECONDS=60
ENGINE_REBALANCE_INTERVAL_SECONDS=300
MAX_DRAWDOWN_PCT=0.20
MAX_EXPOSURE_PCT=0.90
MAX_SIMULTANEOUS_TRADES=40
TARGET_TRADES_MIN=100
TARGET_TRADES_MAX=300
